NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=database

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
